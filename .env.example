# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# GOOGLE_WEB_CLIENT_ID: Optional. Specifies the OAuth Web Client ID for Google Sign-In.
# If not provided, it falls back to the client_id specified in google-services.json.
GOOGLE_WEB_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
